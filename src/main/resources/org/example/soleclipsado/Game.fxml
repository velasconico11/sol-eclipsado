            <Insets />
         </VBox.margin>
      </ImageView>
      <Label alignment="CENTER" prefHeight="26.0" prefWidth="258.0" text="&quot;¡Adivina la palabra!&quot;" textAlignment="CENTER">
         <VBox.margin>
            <Insets />
         </VBox.margin>
         <font>
            <Font size="21.0" />
         </font>
      </Label>
      <HBox fx:id="contenedorLetras" alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0" />
      <Button fx:id="btnAyuda" mnemonicParsing="false" onAction="#handleAyuda" text="Ayuda" />
      <Label fx:id="lblMensaje" textFill="#ff0404" />
   </children>
